@{
    ViewData["Title"] = "Login";
}

<div class="container d-flex justify-content-center align-items-center vh-100">

    <div class="card shadow p-4" style="width: 400px;">

        <h3 class="text-center mb-4">Área do Cliente</h3>

        <!-- Abas -->
        <ul class="nav nav-tabs">

            <!-- Login NÃO ativo -->
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#login">
                    Login
                </button>
            </li>

            <!-- Cadastro ATIVO -->
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#cadastro">
                    Cadastro
                </button>
            </li>

        </ul>

        <div class="tab-content mt-3">

            <!-- LOGIN escondido -->
            <div class="tab-pane fade" id="login">

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label">Senha</label>
                    <input type="password" class="form-control">
                </div>

                <button class="btn btn-primary w-100">Entrar</button>

                <div class="text-center mt-2">
                    <a asp-controller="Conta" asp-action="Esqueciasenha">Esqueci minha senha</a>
                </div>

            </div>

            <!-- CADASTRO VISÍVEL -->
            <div class="tab-pane fade show active" id="cadastro">

                <div class="mb-3">
                    <label class="form-label">Nome</label>
                    <input type="text" class="form-control" placeholder="Digite seu nome">
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" placeholder="Digite seu email">
                </div>

                <div class="mb-3">
                    <label class="form-label">Senha</label>
                    <input type="password" class="form-control" placeholder="Digite sua senha">
                </div>

                <button class="btn btn-success w-100">Cadastrar</button>

            </div>

        </div>

    </div>

</div>

<!-- JS do Bootstrap (IMPORTANTE para funcionar as abas) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>